{
  "name": "feralui",
  "version": "0.1.0",
  "description": "Feral UI – animated React component library",
  "type": "module",
  "main": "./dist/feralui.js",
  "module": "./dist/feralui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/feralui.js",
      "types": "./dist/index.d.ts"
    },
    "./styles/*": "./styles/*"
  },
  "sideEffects": ["**/*.css"],
  "files": [
    "dist",
    "styles"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "motion": ">=11"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "motion": "^11.18.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
